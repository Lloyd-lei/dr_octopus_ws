<?xml version="1.0"?>
<!--
  Dr Octopus Arm URDF
  9-DOF + EE: J1 J2 J3' J4' J3 J4 J5 J6 J7 EE
  Based on OpenArmX with additional J3'/J4' extension
  
  Kinematic chain (from STEP assembly):
  - 右臂: L0R -> L1R -> L2R -> L3 -> L41 (first segment)
  - 右臂 - 副本: L3 -> L4 -> L5R -> L6R -> L7R -> EE (second segment with extension)
-->
<robot name="dr_octopus_arm">

  <!-- Colors -->
  <material name="white">
    <color rgba="1.0 1.0 1.0 1.0"/>
  </material>
  <material name="grey">
    <color rgba="0.7 0.7 0.7 1.0"/>
  </material>
  <material name="blue">
    <color rgba="0.2 0.4 0.8 1.0"/>
  </material>
  <material name="orange">
    <color rgba="1.0 0.5 0.0 1.0"/>
  </material>

  <!-- Base Link -->
  <link name="base_link">
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <!-- Link 0 (L0R) - Shoulder Base -->
  <link name="link0">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 -3.1416"/>
      <geometry>
        <mesh filename="package://dr_octopus_ws/meshes/visual/L0R.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 -3.1416"/>
      <geometry>
        <mesh filename="package://dr_octopus_ws/meshes/visual/L0R.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <origin xyz="0 0 0.029" rpy="0 0 0"/>
      <inertia ixx="0.0005" ixy="0" ixz="0" iyy="0.0005" iyz="0" izz="0.0003"/>
    </inertial>
  </link>

  <joint name="base_to_link0" type="fixed">
    <parent link="base_link"/>
    <child link="link0"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Link 1 (L1R) -->
  <link name="link1">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 -3.1416"/>
      <geometry>
        <mesh filename="package://dr_octopus_ws/meshes/visual/L1R.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 -3.1416"/>
      <geometry>
        <mesh filename="package://dr_octopus_ws/meshes/visual/L1R.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.4"/>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <inertia ixx="0.0006" ixy="0" ixz="0" iyy="0.0006" iyz="0" izz="0.0003"/>
    </inertial>
  </link>

  <!-- Joint 1: Shoulder Yaw (Z-axis) -->
  <joint name="joint1" type="revolute">
    <parent link="link0"/>
    <child link="link1"/>
    <origin xyz="0 0 0.058" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.0944" upper="2.0944" effort="50" velocity="2.0"/>
  </joint>

  <!-- Link 2 (L2R) -->
  <link name="link2">
    <visual>
      <origin xyz="0 0 0" rpy="1.515 0 -1.5708"/>
      <geometry>
        <mesh filename="package://dr_octopus_ws/meshes/visual/L2R.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.515 0 -1.5708"/>
      <geometry>
        <mesh filename="package://dr_octopus_ws/meshes/visual/L2R.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.35"/>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <inertia ixx="0.0005" ixy="0" ixz="0" iyy="0.0005" iyz="0" izz="0.0003"/>
    </inertial>
  </link>

  <!-- Joint 2: Shoulder Pitch (X-axis) -->
  <joint name="joint2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="-0.0205 0 0.081" rpy="0 0 0"/>
    <axis xyz="-1 0 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="50" velocity="2.0"/>
  </joint>

  <!-- ========== NEW: J3' J4' Extension (L-Bracket) ========== -->
  
  <!-- Link 3 Prime (L3 from 右臂) - First part of extension -->
  <link name="link3_prime">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 -1.5708"/>
      <geometry>
        <mesh filename="package://dr_octopus_ws/meshes/visual/L3.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 -1.5708"/>
      <geometry>
        <mesh filename="package://dr_octopus_ws/meshes/visual/L3.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <origin xyz="0 0 0.07" rpy="0 0 0"/>
      <inertia ixx="0.0004" ixy="0" ixz="0" iyy="0.0004" iyz="0" izz="0.0002"/>
    </inertial>
  </link>

  <!-- Joint 3 Prime: Shoulder Rotation Extension (Z-axis) -->
  <joint name="joint3_prime" type="revolute">
    <parent link="link2"/>
    <child link="link3_prime"/>
    <origin xyz="0.02 0 0.099" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.618" upper="2.618" effort="50" velocity="2.0"/>
  </joint>

  <!-- Link 4 Prime (L41) - Second part of extension (L-bracket) -->
  <link name="link4_prime">
    <visual>
      <origin xyz="0 0 0" rpy="1.178 0 -1.5708"/>
      <geometry>
        <mesh filename="package://dr_octopus_ws/meshes/visual/L41.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.178 0 -1.5708"/>
      <geometry>
        <mesh filename="package://dr_octopus_ws/meshes/visual/L41.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.25"/>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <inertia ixx="0.0003" ixy="0" ixz="0" iyy="0.0003" iyz="0" izz="0.0002"/>
    </inertial>
  </link>

  <!-- Joint 4 Prime: Elbow Extension (Y-axis) -->
  <joint name="joint4_prime" type="revolute">
    <parent link="link3_prime"/>
    <child link="link4_prime"/>
    <origin xyz="0 0.031 0.142" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.356" upper="2.356" effort="50" velocity="2.0"/>
  </joint>

  <!-- ========== Original J3-J7 Chain (继续接入) ========== -->

  <!-- Link 3 (L3_2 from 右臂 - 副本) -->
  <link name="link3">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 -1.5708"/>
      <geometry>
        <mesh filename="package://dr_octopus_ws/meshes/visual/L3_2.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 -1.5708"/>
      <geometry>
        <mesh filename="package://dr_octopus_ws/meshes/visual/L3_2.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <origin xyz="0 0 0.07" rpy="0 0 0"/>
      <inertia ixx="0.0004" ixy="0" ixz="0" iyy="0.0004" iyz="0" izz="0.0002"/>
    </inertial>
  </link>

  <!-- Joint 3: Upper Arm Rotation (Z-axis) -->
  <joint name="joint3" type="revolute">
    <parent link="link4_prime"/>
    <child link="link3"/>
    <origin xyz="0 -0.031 0.066" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.618" upper="2.618" effort="50" velocity="2.0"/>
  </joint>

  <!-- Link 4 (L4) -->
  <link name="link4">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 -1.5708"/>
      <geometry>
        <mesh filename="package://dr_octopus_ws/meshes/visual/L4.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 -1.5708"/>
      <geometry>
        <mesh filename="package://dr_octopus_ws/meshes/visual/L4.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.28"/>
      <origin xyz="0 0.015 0.07" rpy="0 0 0"/>
      <inertia ixx="0.0004" ixy="0" ixz="0" iyy="0.0004" iyz="0" izz="0.0002"/>
    </inertial>
  </link>

  <!-- Joint 4: Elbow (Y-axis) -->
  <joint name="joint4" type="revolute">
    <parent link="link3"/>
    <child link="link4"/>
    <origin xyz="0 0.031 0.142" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.356" upper="2.356" effort="50" velocity="2.0"/>
  </joint>

  <!-- Link 5 (L5R) -->
  <link name="link5">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 -1.5708"/>
      <geometry>
        <mesh filename="package://dr_octopus_ws/meshes/visual/L5R.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 -1.5708"/>
      <geometry>
        <mesh filename="package://dr_octopus_ws/meshes/visual/L5R.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.25"/>
      <origin xyz="0 0 0.063" rpy="0 0 0"/>
      <inertia ixx="0.0003" ixy="0" ixz="0" iyy="0.0003" iyz="0" izz="0.0002"/>
    </inertial>
  </link>

  <!-- Joint 5: Forearm Rotation (Z-axis) -->
  <joint name="joint5" type="revolute">
    <parent link="link4"/>
    <child link="link5"/>
    <origin xyz="0 -0.031 0.126" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.618" upper="2.618" effort="30" velocity="2.5"/>
  </joint>

  <!-- Link 6 (L6R) -->
  <link name="link6">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 -1.5708"/>
      <geometry>
        <mesh filename="package://dr_octopus_ws/meshes/visual/L6R.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 -1.5708"/>
      <geometry>
        <mesh filename="package://dr_octopus_ws/meshes/visual/L6R.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <origin xyz="0.02 0 0.065" rpy="0 0 0"/>
      <inertia ixx="0.0002" ixy="0" ixz="0" iyy="0.0002" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <!-- Joint 6: Wrist Pitch (X-axis) -->
  <joint name="joint6" type="revolute">
    <parent link="link5"/>
    <child link="link6"/>
    <origin xyz="0.037 0 0.131" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="20" velocity="3.0"/>
  </joint>

  <!-- Link 7 (L7R) -->
  <link name="link7">
    <visual>
      <origin xyz="0 0 0" rpy="-1.5708 0 1.5708"/>
      <geometry>
        <mesh filename="package://dr_octopus_ws/meshes/visual/L7R.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="-1.5708 0 1.5708"/>
      <geometry>
        <mesh filename="package://dr_octopus_ws/meshes/visual/L7R.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.15"/>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.00008"/>
    </inertial>
  </link>

  <!-- Joint 7: Wrist Roll (Y-axis) -->
  <joint name="joint7" type="revolute">
    <parent link="link6"/>
    <child link="link7"/>
    <origin xyz="-0.0375 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.618" upper="2.618" effort="15" velocity="3.5"/>
  </joint>

  <!-- End Effector Link -->
  <link name="ee_link">
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <inertia ixx="0.00005" ixy="0" ixz="0" iyy="0.00005" iyz="0" izz="0.00003"/>
    </inertial>
  </link>

  <!-- End Effector Joint -->
  <joint name="joint_ee" type="fixed">
    <parent link="link7"/>
    <child link="ee_link"/>
    <origin xyz="0 0 0.08" rpy="0 0 0"/>
  </joint>

</robot>
